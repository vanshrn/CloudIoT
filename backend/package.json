{
  "name": "cloudiot-backend",
  "version": "0.1.0",
  "private": true,
  "description": "CloudIoT serverless backend — AWS Lambda + API Gateway + CDK infrastructure",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "watch": "tsc -b -w",
    "clean": "tsc -b --clean",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "cdk": "cdk",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy --all",
    "deploy:dev": "cdk deploy --all -c stage=dev",
    "destroy": "cdk destroy --all"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1089.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1088.0",
    "@aws-sdk/client-dynamodb": "^3.637.0",
    "@aws-sdk/client-iot": "^3.1087.0",
    "@aws-sdk/client-s3": "^3.1088.0",
    "@aws-sdk/lib-dynamodb": "^3.637.0",
    "@aws-sdk/s3-request-presigner": "^3.1088.0",
    "@aws-sdk/util-dynamodb": "^3.996.7",
    "aws-cdk-lib": "^2.160.0",
    "aws-jwt-verify": "^4.0.1",
    "constructs": "^10.3.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "aws-cdk": "^2.160.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
